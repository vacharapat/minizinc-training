%   "=== แผนการผลิต ===\n",
%   "ผลิตภัณฑ์ A: ", show(a), " หน่วย\n",
%   "ผลิตภัณฑ์ B: ", show(b), " หน่วย\n",
%   "แรงงานที่ใช้: ", show(3*a + 5*b), "/", show(labor_hours), " ชม.\n",
%   "วัตถุดิบที่ใช้: ", show(5*a + 2*b), "/", show(raw_material), " กก.\n",
